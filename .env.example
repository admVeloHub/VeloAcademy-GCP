# v1.1.0 | VeloAcademy — copie para FONTE DA VERDADE/.env (ou .env na raiz deste repo em dev)
# Não coloque segredos reais neste ficheiro; o template pode ser versionado.

# Obrigatório para API com MongoDB (produção: Secret Manager / env do Cloud Run)
MONGO_ENV=mongodb://localhost:27017

# Google OAuth (Web) — o servidor expõe em GET /api/config/google-client.js (mesmo em Cloud Run)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Opcional; default academy_registros
# DB_NAME_ACADEMY=academy_registros

# YouTube Data API (tutoriais home)
# YOUTUBE_DATA_API_KEY=
# YOUTUBE_TUTORIAS_PLAYLIST_ID=

# Apenas depuração local; não definir em produção
# DEBUG_LOGIN=1

# Porta: Cloud Run injeta PORT; em dev, server-api.js usa 3001 por padrão
# PORT=3001
